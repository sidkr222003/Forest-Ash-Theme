{
  "name": "forest-ash-theme",
  "displayName": "Forest Ash Theme",
  "description": "A collection of dark and light, eye-friendly VS Code themes inspired by forest ash textures and anime palettes with custom colors, accessibility, mood switching, language auto-theming, and developer personas.",
  "version": "1.4.0",
  "publisher": "NK2552003",
  "main": "./extension.js",
  "engines": {"vscode": "^1.70.0"},
  "categories": ["Themes"],
  "keywords": ["vscode", "theme", "forest", "ash", "dark", "light", "anime", "eye-friendly", "paper-like", "customizable", "accessibility"],
  "license": "MIT",
  "icon": "icon.png",
  "repository": {"type": "git", "url": "https://github.com/sidkr222003/Forest-Ash-Theme"},
  "bugs": {"url": "https://github.com/sidkr222003/Forest-Ash-Theme/issues"},
  "homepage": "https://github.com/sidkr222003/Forest-Ash-Theme",
  "activationEvents": [
    "onCommand:forest-ash-theme.pickAccentColor",
    "onCommand:forest-ash-theme.customAccentColor",
    "onCommand:forest-ash-theme.revertAccentColor",
    "onCommand:forest-ash-theme.toggleHighContrast",
    "onCommand:forest-ash-theme.exportAccentColor",
    "onCommand:forest-ash-theme.switchMood",
    "onCommand:forest-ash-theme.toggleMoodTheming",
    "onCommand:forest-ash-theme.toggleLanguageAutoTheme",
    "onCommand:forest-ash-theme.customizeLanguageIntensity",
    "onCommand:forest-ash-theme.applyPersonaPreset",
    "onCommand:forest-ash-theme.showPersonaRecommendations"
  ],
  "scripts": {
    "package": "vsce package",
    "publish": "vsce publish",
    "prepublishOnly": "echo \"Skipping prepublish hook to avoid recursive npm run package\""
  },
  "devDependencies": {
    "vsce": "^2.0.0"
  },
  "contributes": {
    "themes": [
      {"label": "Forest Ash", "uiTheme": "vs-dark", "path": "themes/forest-ash-color-theme.json"},
      {"label": "Forest Ash Yoru Paper", "uiTheme": "vs-dark", "path": "themes/forest-ash-yoru-paper-color-theme.json"},
