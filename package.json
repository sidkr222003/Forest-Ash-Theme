    "commands": [
      {
        "command": "forest-ash-theme.pickAccentColor",
        "title": "Forest Ash: Pick Accent Color",
        "category": "Forest Ash Theme"
      },
      {
        "command": "forest-ash-theme.customAccentColor",
        "title": "Forest Ash: Custom Accent Color",
        "category": "Forest Ash Theme"
      },
      {
        "command": "forest-ash-theme.revertAccentColor",
        "title": "Forest Ash: Revert Accent Color",
        "category": "Forest Ash Theme"
      },
      {
        "command": "forest-ash-theme.toggleHighContrast",
        "title": "Forest Ash: Toggle WCAG High Contrast",
        "category": "Forest Ash Theme"
      },
      {
        "command": "forest-ash-theme.exportAccentColor",
        "title": "Forest Ash: Export Accent Color",
        "category": "Forest Ash Theme"
      },
      {
        "command": "forest-ash-theme.switchMood",
        "title": "Forest Ash: Switch Mood",
        "category": "Forest Ash Theme"
      },
      {
        "command": "forest-ash-theme.toggleMoodTheming",
        "title": "Forest Ash: Toggle Mood-Based Theming",
        "category": "Forest Ash Theme"
      },
      {
        "command": "forest-ash-theme.toggleLanguageAutoTheme",
        "title": "Forest Ash: Toggle Language Auto-Theme",
        "category": "Forest Ash Theme"
      },
      {
        "command": "forest-ash-theme.customizeLanguageIntensity",
        "title": "Forest Ash: Customize Language Accent Intensity",
        "category": "Forest Ash Theme"
      },
      {
        "command": "forest-ash-theme.applyPersonaPreset",
        "title": "Forest Ash: Apply Developer Persona",
        "category": "Forest Ash Theme"
      },
      {
        "command": "forest-ash-theme.showPersonaRecommendations",
        "title": "Forest Ash: Show Persona Recommendations",
        "category": "Forest Ash Theme"
      }
    ],
    "configuration": {
      "title": "Forest Ash Theme",
      "properties": {
        "forestAshTheme.customAccentColor": {
          "type": "string",
          "default": null,
          "description": "Custom accent color for all Forest Ash themes. Accepts hex (#RRGGBB), RGB (rgb(r,g,b)), or HSL (hsl(h,s%,l%)) formats.",
          "examples": ["#A8D8EA", "rgb(168, 216, 234)", "hsl(180, 70%, 79%)"]
        },
        "forestAshTheme.wcagHighContrast": {
          "type": "boolean",
          "default": false,
          "description": "Enable WCAG AAA high contrast variant of the current theme. Disabled by default."
        },
        "forestAshTheme.enableMoodTheming": {
          "type": "boolean",
          "default": false,
          "description": "Enable mood-based theme variants. Choose between Happy, Focused, Tired, and Creative moods. Disabled by default."
        },
        "forestAshTheme.currentMood": {
          "type": "string",
          "default": "focused",
          "enum": ["happy", "focused", "tired", "creative"],
          "description": "Current mood for theme rendering. Only applies when enableMoodTheming is true."
        },
        "forestAshTheme.enableLanguageAutoTheme": {
          "type": "boolean",
          "default": false,
          "description": "Enable automatic language-based accent color application. Applies subtle color shifts based on active file language. Disabled by default."
        },
        "forestAshTheme.languageAccentIntensity": {
          "type": "number",
          "default": 0.3,
          "minimum": 0,
          "maximum": 1,
          "description": "Intensity of language-based accent color (0.0 - 1.0). Lower values are more subtle."
        },
        "forestAshTheme.developerPersona": {
          "type": "string",
          "default": null,
          "enum": ["hacker", "designer", "datascientist", "minimalist", "artistic"],
          "description": "Selected developer persona preset. Customizes syntax highlighting and color philosophy."
        }
      }
    }
  }
}
