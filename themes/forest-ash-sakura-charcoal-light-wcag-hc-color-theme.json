  "tokenColors": [
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#B784A0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#A45077",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type"
      ],
      "settings": {
        "foreground": "#A44675",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "variable"
      ],
      "settings": {
        "foreground": "#5A4852",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#98476E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type"
      ],
      "settings": {
        "foreground": "#8B4A67",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#834768",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.bracket",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#7B5067",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "string.key",
        "entity.name.tag",
        "support.class"
      ],
      "settings": {
        "foreground": "#994B70",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#DC4B66",
        "fontStyle": "underline"
      }
    },
    {
      "name": "JSON key",
      "scope": [
        "meta.structure.dictionary.key.json",
        "string.key.json",
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#8B4A67",
        "fontStyle": "bold"
      }
    },
    {
      "name": "JSON value",
      "scope": [
        "meta.structure.dictionary.value.json",
        "constant.numeric.json",
        "constant.language.json",
        "string.quoted.double.json",
        "variable.other.json"
      ],
      "settings": {
        "foreground": "#98476C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "source.json",
        "meta.structure.dictionary.json",
        "string.quoted.double.json",
        "constant.numeric.json",
        "constant.language.json",
        "punctuation.definition.string.begin.json",
        "punctuation.definition.string.end.json",
        "meta.structure.dictionary.value.json"
      ],
      "settings": {
        "foreground": "#98476C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "source.tsx",
        "meta.tag.tsx",
        "punctuation.definition.tag.tsx",
        "entity.name.tag.tsx",
        "meta.jsx.children",
        "meta.embedded.block.tsx"
      ],
      "settings": {
        "foreground": "#994B70",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#5A4852",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Forest Ash - Keywords Extended",
      "scope": [
        "keyword.control",
        "keyword.operator",
        "storage.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#A44675",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Forest Ash - Strings Extended",
      "scope": [
        "string.quoted",
        "string.template",
        "punctuation.definition.string",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#A45077",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Forest Ash - Numbers & Booleans",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null"
      ],
      "settings": {
        "foreground": "#98476E",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Forest Ash - Functions Extended",
      "scope": [
        "entity.name.function",
        "variable.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#834768",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Forest Ash - Types Extended",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type",
        "entity.name.class",
        "entity.name.interface"
      ],
      "settings": {
        "foreground": "#8B4A67",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Forest Ash - Variables Extended",
      "scope": [
        "variable.other.readwrite",
        "variable.parameter",
        "variable.object.property",
        "support.variable"
      ],
      "settings": {
        "foreground": "#5A4852",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Forest Ash - Constants Extended",
      "scope": [
        "constant",
        "constant.other",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#98476E",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable": "#3C2A34",
    "parameter": "#3C2A34EB",
    "property": "#3C2A34E6",
    "function": "#65294A",
    "method": "#65294A",
    "class": "#6D2C49",
    "interface": "#6D2C49E6",
    "type": "#6D2C49",
    "enum": "#6D2C49E0",
    "namespace": "#6D2C49D9",
    "keyword": "#862857",
    "string": "#863259",
    "number": "#7A2950",
    "comment": "#996682"
  }
}