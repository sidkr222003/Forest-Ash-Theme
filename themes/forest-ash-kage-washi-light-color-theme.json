  "tokenColors": [
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#66998B",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#328668"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type"
      ],
      "settings": {
        "foreground": "#288665",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "variable"
      ],
      "settings": {
        "foreground": "#2A3C2E"
      }
    },
    {
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#297A5A"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type"
      ],
      "settings": {
        "foreground": "#2C6D54"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#29654D"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.bracket",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#325D50"
      }
    },
    {
      "scope": [
        "string.key",
        "entity.name.tag",
        "support.class"
      ],
      "settings": {
        "foreground": "#2D7B5C"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#BF465C",
        "fontStyle": "underline"
      }
    },
    {
      "name": "JSON key",
      "scope": [
        "meta.structure.dictionary.key.json",
        "string.key.json",
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#2C6D54",
        "fontStyle": "bold"
      }
    },
    {
      "name": "JSON value",
      "scope": [
        "meta.structure.dictionary.value.json",
        "constant.numeric.json",
        "constant.language.json",
        "string.quoted.double.json",
        "variable.other.json"
      ],
      "settings": {
        "foreground": "#297A5D"
      }
    },
    {
      "scope": [
        "source.json",
        "meta.structure.dictionary.json",
        "string.quoted.double.json",
        "constant.numeric.json",
        "constant.language.json",
        "punctuation.definition.string.begin.json",
        "punctuation.definition.string.end.json",
        "meta.structure.dictionary.value.json"
      ],
      "settings": {
        "foreground": "#297A5D"
      }
    },
    {
      "scope": [
        "source.tsx",
        "meta.tag.tsx",
        "punctuation.definition.tag.tsx",
        "entity.name.tag.tsx",
        "meta.jsx.children",
        "meta.embedded.block.tsx"
      ],
      "settings": {
        "foreground": "#2D7B5C"
      }
    },
    {
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#2A3C2E"
      }
    },
    {
      "name": "Forest Ash - Keywords Extended",
      "scope": [
        "keyword.control",
        "keyword.operator",
        "storage.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#288665",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Forest Ash - Strings Extended",
      "scope": [
        "string.quoted",
        "string.template",
        "punctuation.definition.string",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#328668"
      }
    },
    {
      "name": "Forest Ash - Numbers & Booleans",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null"
      ],
      "settings": {
        "foreground": "#297A5A"
      }
    },
    {
      "name": "Forest Ash - Functions Extended",
      "scope": [
        "entity.name.function",
        "variable.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#29654D"
      }
    },
    {
      "name": "Forest Ash - Types Extended",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type",
        "entity.name.class",
        "entity.name.interface"
      ],
      "settings": {
        "foreground": "#2C6D54"
      }
    },
    {
      "name": "Forest Ash - Variables Extended",
      "scope": [
        "variable.other.readwrite",
        "variable.parameter",
        "variable.object.property",
        "support.variable"
      ],
      "settings": {
        "foreground": "#2A3C2E"
      }
    },
    {
      "name": "Forest Ash - Constants Extended",
      "scope": [
        "constant",
        "constant.other",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#297A5A"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable": "#2A3C2E",
    "parameter": "#2A3C2EEB",
    "property": "#2A3C2EE6",
    "function": "#29654D",
    "method": "#29654D",
    "class": "#2C6D54",
    "interface": "#2C6D54E6",
    "type": "#2C6D54",
    "enum": "#2C6D54E0",
    "namespace": "#2C6D54D9",
    "keyword": "#288665",
    "string": "#328668",
    "number": "#297A5A",
    "comment": "#66998B"
  }
}
