  "tokenColors": [
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#97A6B8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#9DC1F7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type"
      ],
      "settings": {
        "foreground": "#E2D09C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "variable"
      ],
      "settings": {
        "foreground": "#F3FDFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#C1DBFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type"
      ],
      "settings": {
        "foreground": "#BBD6FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#DCF0FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.bracket",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#AAB7C6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "string.key",
        "entity.name.tag",
        "support.class"
      ],
      "settings": {
        "foreground": "#D1E6FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFABBC",
        "fontStyle": "underline"
      }
    },
    {
      "name": "JSON key",
      "scope": [
        "meta.structure.dictionary.key.json",
        "string.key.json",
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#BBD6FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "JSON value",
      "scope": [
        "meta.structure.dictionary.value.json",
        "constant.numeric.json",
        "constant.language.json",
        "string.quoted.double.json",
        "variable.other.json"
      ],
      "settings": {
        "foreground": "#9DC1F7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "source.json",
        "meta.structure.dictionary.json",
        "string.quoted.double.json",
        "constant.numeric.json",
        "constant.language.json",
        "punctuation.definition.string.begin.json",
        "punctuation.definition.string.end.json",
        "meta.structure.dictionary.value.json"
      ],
      "settings": {
        "foreground": "#9DC1F7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "source.tsx",
        "meta.tag.tsx",
        "punctuation.definition.tag.tsx",
        "entity.name.tag.tsx",
        "meta.jsx.children",
        "meta.embedded.block.tsx"
      ],
      "settings": {
        "foreground": "#D1E6FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#F3FDFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Forest Ash - Keywords Extended",
      "scope": [
        "keyword.control",
        "keyword.operator",
        "storage.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#E2D09C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Forest Ash - Strings Extended",
      "scope": [
        "string.quoted",
        "string.template",
        "punctuation.definition.string",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#9DC1F7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Forest Ash - Numbers & Booleans",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null"
      ],
      "settings": {
        "foreground": "#C1DBFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Forest Ash - Functions Extended",
      "scope": [
        "entity.name.function",
        "variable.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#DCF0FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Forest Ash - Types Extended",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type",
        "entity.name.class",
        "entity.name.interface"
      ],
      "settings": {
        "foreground": "#BBD6FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Forest Ash - Variables Extended",
      "scope": [
        "variable.other.readwrite",
        "variable.parameter",
        "variable.object.property",
        "support.variable"
      ],
      "settings": {
        "foreground": "#F3FDFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Forest Ash - Constants Extended",
      "scope": [
        "constant",
        "constant.other",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#C1DBFF",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable": "#D5DFEA",
    "parameter": "#D5DFEAF2",
    "property": "#D5DFEAEB",
    "function": "#BED2F3",
    "method": "#BED2F3",
    "class": "#9DB8E8",
    "interface": "#9DB8E8F2",
    "type": "#9DB8E8",
    "enum": "#9DB8E8ED",
    "namespace": "#9DB8E8E6",
    "keyword": "#C4B27E",
    "string": "#7FA3D9",
    "number": "#A3BDEB",
    "comment": "#79889A"
  }
}