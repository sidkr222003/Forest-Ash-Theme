  "tokenColors": [
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#7F86A0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#9FA6E8"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type"
      ],
      "settings": {
        "foreground": "#C7B97F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "variable"
      ],
      "settings": {
        "foreground": "#DADDED"
      }
    },
    {
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#B6BCF0"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type"
      ],
      "settings": {
        "foreground": "#BDC1F7"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#CED2FA"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.bracket",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#9197AD"
      }
    },
    {
      "scope": [
        "string.key",
        "entity.name.tag",
        "support.class"
      ],
      "settings": {
        "foreground": "#CACDF8"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#EB93AE",
        "fontStyle": "underline"
      }
    },
    {
      "name": "JSON key",
      "scope": [
        "meta.structure.dictionary.key.json",
        "string.key.json",
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#BDC1F7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "JSON value",
      "scope": [
        "meta.structure.dictionary.value.json",
        "constant.numeric.json",
        "constant.language.json",
        "string.quoted.double.json",
        "variable.other.json"
      ],
      "settings": {
        "foreground": "#9FA6E8"
      }
    },
    {
      "scope": [
        "source.json",
        "meta.structure.dictionary.json",
        "string.quoted.double.json",
        "constant.numeric.json",
        "constant.language.json",
        "punctuation.definition.string.begin.json",
        "punctuation.definition.string.end.json",
        "meta.structure.dictionary.value.json"
      ],
      "settings": {
        "foreground": "#9FA6E8"
      }
    },
    {
      "scope": [
        "source.tsx",
        "meta.tag.tsx",
        "punctuation.definition.tag.tsx",
        "entity.name.tag.tsx",
        "meta.jsx.children",
        "meta.embedded.block.tsx"
      ],
      "settings": {
        "foreground": "#CACDF8"
      }
    },
    {
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#DADDED"
      }
    },
    {
      "name": "Forest Ash - Keywords Extended",
      "scope": [
        "keyword.control",
        "keyword.operator",
        "storage.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#C7B97F",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Forest Ash - Strings Extended",
      "scope": [
        "string.quoted",
        "string.template",
        "punctuation.definition.string",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#9FA6E8"
      }
    },
    {
      "name": "Forest Ash - Numbers & Booleans",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null"
      ],
      "settings": {
        "foreground": "#B6BCF0"
      }
    },
    {
      "name": "Forest Ash - Functions Extended",
      "scope": [
        "entity.name.function",
        "variable.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#CED2FA"
      }
    },
    {
      "name": "Forest Ash - Types Extended",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type",
        "entity.name.class",
        "entity.name.interface"
      ],
      "settings": {
        "foreground": "#BDC1F7"
      }
    },
    {
      "name": "Forest Ash - Variables Extended",
      "scope": [
        "variable.other.readwrite",
        "variable.parameter",
        "variable.object.property",
        "support.variable"
      ],
      "settings": {
        "foreground": "#DADDED"
      }
    },
    {
      "name": "Forest Ash - Constants Extended",
      "scope": [
        "constant",
        "constant.other",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#B6BCF0"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable": "#DADDED",
    "parameter": "#DADDEDF2",
    "property": "#DADDEDEB",
    "function": "#CED2FA",
    "method": "#CED2FA",
    "class": "#BDC1F7",
    "interface": "#BDC1F7F2",
    "type": "#BDC1F7",
    "enum": "#BDC1F7ED",
    "namespace": "#BDC1F7E6",
    "keyword": "#C7B97F",
    "string": "#9FA6E8",
    "number": "#B6BCF0",
    "comment": "#7F86A0"
  }
}
