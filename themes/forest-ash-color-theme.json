  "tokenColors": [
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#8FA79A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#6FAF97"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type"
      ],
      "settings": {
        "foreground": "#D6B56C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "variable"
      ],
      "settings": {
        "foreground": "#DCE5DF"
      }
    },
    {
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#A2D9BC"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type"
      ],
      "settings": {
        "foreground": "#9EE0BA"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#8FC3D8"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.bracket",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#94B89B"
      }
    },
    {
      "scope": [
        "string.key",
        "entity.name.tag",
        "support.class"
      ],
      "settings": {
        "foreground": "#B4DCC3"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#F5635D",
        "fontStyle": "underline"
      }
    },
    {
      "name": "JSON key",
      "scope": [
        "meta.structure.dictionary.key.json",
        "string.key.json",
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#B4DCC3",
        "fontStyle": "bold"
      }
    },
    {
      "name": "JSON value",
      "scope": [
        "meta.structure.dictionary.value.json",
        "constant.numeric.json",
        "constant.language.json",
        "string.quoted.double.json",
        "variable.other.json"
      ],
      "settings": {
        "foreground": "#A2D9BC"
      }
    },
    {
      "scope": [
        "source.json",
        "meta.structure.dictionary.json",
        "string.quoted.double.json",
        "constant.numeric.json",
        "constant.language.json",
        "punctuation.definition.string.begin.json",
        "punctuation.definition.string.end.json",
        "meta.structure.dictionary.value.json"
      ],
      "settings": {
        "foreground": "#A2D9BC"
      }
    },
    {
      "scope": [
        "source.tsx",
        "meta.tag.tsx",
        "punctuation.definition.tag.tsx",
        "entity.name.tag.tsx",
        "meta.jsx.children",
        "meta.embedded.block.tsx"
      ],
      "settings": {
        "foreground": "#9EE0BA"
      }
    },
    {
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#DCE5DF"
      }
    },
    {
      "name": "Forest Ash - Keywords Extended",
      "scope": [
        "keyword.control",
        "keyword.operator",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D6B56C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Forest Ash - Strings Extended",
      "scope": [
        "string.quoted",
        "string.template",
        "punctuation.definition.string",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#6FAF97"
      }
    },
    {
      "name": "Forest Ash - Numbers & Booleans",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null"
      ],
      "settings": {
        "foreground": "#A2D9BC"
      }
    },
    {
      "name": "Forest Ash - Functions Extended",
      "scope": [
        "entity.name.function",
        "variable.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#8FC3D8"
      }
    },
    {
      "name": "Forest Ash - Types Extended",
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.name.class",
        "entity.name.interface"
      ],
      "settings": {
        "foreground": "#9EE0BA"
      }
    },
    {
      "name": "Forest Ash - Variables Extended",
      "scope": [
        "variable.other.readwrite",
        "variable.parameter",
        "variable.object.property",
        "support.variable"
      ],
      "settings": {
        "foreground": "#DCE5DF"
      }
    },
    {
      "name": "Forest Ash - Constants Extended",
      "scope": [
        "constant",
        "constant.other",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#A2D9BC"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable": "#DCE5DF",
    "parameter": "#DCE5DFF2",
    "property": "#DCE5DFEB",
    "function": "#8FC3D8",
    "method": "#8FC3D8",
    "class": "#9EE0BA",
    "interface": "#9EE0BAF2",
    "type": "#9EE0BA",
    "enum": "#9EE0BAED",
    "namespace": "#9EE0BAE6",
    "keyword": "#D6B56C",
    "string": "#6FAF97",
    "number": "#A2D9BC",
    "comment": "#8FA79A"
  }
}
